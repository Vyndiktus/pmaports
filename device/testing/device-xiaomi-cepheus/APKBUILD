pkgname=device-xiaomi-cepheus
pkgdesc="Xiaomi Mi 9 (NerveOS)"
pkgver=1
pkgrel=3
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	linux-postmarketos-qcom-sm8150
	mkbootimg
	postmarketos-base
"
makedepends="devicepkg-dev"
source="deviceinfo
	nerveos-os-release
	nerveos-motd"

build() {
	devicepkg_build  
}

package() {
	devicepkg_package  
	# NerveOS branding: override os-release and install motd
	install -Dm644 "/nerveos-os-release" "/etc/os-release"
	install -Dm644 "/nerveos-motd" "/etc/motd"
}

